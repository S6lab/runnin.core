<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- health-services-client declara minSdk=30 hard no manifest da lib,
         mas o app é minSdk=26 (cobre Android 8+). Override força o merge a
         aceitar — runtime guard (Build.VERSION.SDK_INT < R) no
         WorkoutRealtimePlugin.kt já bloqueia uso em devices < Android 11,
         então não há risco de NoClassDefFoundError. -->
    <uses-sdk tools:overrideLibrary="androidx.health.services.client" />

    <!-- GPS permissions -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />
    <!-- Background service -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <!-- Internet -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Microphone (Coach Live multimodal) -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <!-- BPM realtime durante Run ativa (Health Services + MeasureClient).
         BODY_SENSORS é exigido pelo MeasureClient pra heart rate live.
         Sem BODY_SENSORS_BACKGROUND (escopo phone-only com FG service GPS
         mantém vivo). Sem BLUETOOTH_* (Health Services abstrai BLE). -->
    <uses-permission android:name="android.permission.BODY_SENSORS" />
    <!-- Google Health Connect — leitura -->
    <uses-permission android:name="android.permission.health.READ_HEART_RATE" />
    <uses-permission android:name="android.permission.health.READ_RESTING_HEART_RATE" />
    <uses-permission android:name="android.permission.health.READ_HEART_RATE_VARIABILITY" />
    <uses-permission android:name="android.permission.health.READ_SLEEP" />
    <uses-permission android:name="android.permission.health.READ_STEPS" />
    <uses-permission android:name="android.permission.health.READ_OXYGEN_SATURATION" />
    <uses-permission android:name="android.permission.health.READ_WEIGHT" />
    <uses-permission android:name="android.permission.health.READ_ACTIVE_CALORIES_BURNED" />
    <uses-permission android:name="android.permission.health.READ_RESPIRATORY_RATE" />
    <!-- Paridade com iOS: tipos que o health_sync_service já solicita mas
         falhavam silenciosamente no Health Connect por falta da permissão
         declarada (try/catch por tipo engolia o erro). -->
    <uses-permission android:name="android.permission.health.READ_DISTANCE" />
    <uses-permission android:name="android.permission.health.READ_BASAL_METABOLIC_RATE" />
    <uses-permission android:name="android.permission.health.READ_HEIGHT" />
    <uses-permission android:name="android.permission.health.READ_BODY_FAT" />
    <uses-permission android:name="android.permission.health.READ_LEAN_BODY_MASS" />
    <uses-permission android:name="android.permission.health.READ_FLOORS_CLIMBED" />
    <uses-permission android:name="android.permission.health.READ_EXERCISE" />
    <uses-permission android:name="android.permission.health.READ_SPEED" />
    <uses-permission android:name="android.permission.health.READ_TOTAL_CALORIES_BURNED" />
    <uses-permission android:name="android.permission.health.READ_HYDRATION" />

    <application
        android:label="runnin"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
            <!-- Health Connect: Google exige que o app declare uma activity
                 que responde a esta action — é onde o usuário vê o link da
                 política de privacidade durante o request de permissão. Sem
                 isso o Health Connect bloqueia o consent. -->
            <intent-filter>
                <action android:name="androidx.health.ACTION_SHOW_PERMISSIONS_RATIONALE" />
            </intent-filter>
        </activity>

        <!-- Health Connect built-in (Android 14+): exige um receiver pra
             VIEW_PERMISSION_USAGE + category HEALTH_PERMISSIONS. Sem isso,
             o Health Connect classifica o app como "Atualização necessária"
             na lista de apps de saúde e toque leva direto pra Play Store
             em vez de abrir as permissões. activity-alias aponta pra
             MainActivity (que ja tem o handler de ACTION_SHOW_PERMISSIONS_
             RATIONALE) e exige a permissão START_VIEW_PERMISSION_USAGE
             como o sistema requer. -->
        <activity-alias
            android:name="ViewPermissionUsageActivity"
            android:exported="true"
            android:targetActivity=".MainActivity"
            android:permission="android.permission.START_VIEW_PERMISSION_USAGE">
            <intent-filter>
                <action android:name="android.intent.action.VIEW_PERMISSION_USAGE" />
                <category android:name="android.intent.category.HEALTH_PERMISSIONS" />
            </intent-filter>
        </activity-alias>
        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />

        <!-- WearableListenerService — recebe MessageClient/DataClient pushes
             do app Wear OS (Galaxy Watch). Equivalente phone-side do
             SessionDelegate iOS. Filtros pelas paths /runnin/* que nós
             definimos no WearPaths. -->
        <service
            android:name=".PhoneWearableListenerService"
            android:exported="true">
            <intent-filter>
                <action android:name="com.google.android.gms.wearable.MESSAGE_RECEIVED" />
                <data android:scheme="wear" android:host="*"
                      android:pathPrefix="/runnin/" />
            </intent-filter>
            <intent-filter>
                <action android:name="com.google.android.gms.wearable.DATA_CHANGED" />
                <data android:scheme="wear" android:host="*"
                      android:pathPrefix="/runnin/" />
            </intent-filter>
        </service>
    </application>
    <queries>
        <!-- Process text intent (Flutter engine default) -->
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
        <!-- Health Connect: necessário pra detectar o app via PackageManager
             em Android 11+ (package visibility). -->
        <package android:name="com.google.android.apps.healthdata" />
        <!-- Share dedicado: detectar Instagram/WhatsApp pra deeplinks. -->
        <package android:name="com.instagram.android" />
        <package android:name="com.whatsapp" />
        <intent>
            <action android:name="androidx.health.ACTION_SHOW_PERMISSIONS_RATIONALE" />
        </intent>
    </queries>
</manifest>
