# Build artifacts (any depth — covers app/, server/, root)
**/build/
**/dist/
**/coverage/
**/.dart_tool/
**/.gradle/
**/DerivedData/

# Dependencies
**/node_modules/
**/.pub-cache/
**/Pods/

# Logs
**/*.log
**/firebase-debug.log
**/flutter_*.log

# Environment files — never commit, use .env.example as template
**/.env
**/.env.local
**/.env.development
**/.env.staging
**/.env.production

# Flutter / Dart generated
**/.flutter-plugins
**/.flutter-plugins-dependencies
**/.packages
**/generated_plugin_registrant.dart
**/*.freezed.dart
**/*.g.dart

# IDE / OS
**/.DS_Store
**/.idea/
**/*.iml
.vscode/launch.json

# Claude Code (local dev artifact)
.claude/

# Firebase local caches
.firebase/hosting.*.cache

# Google Cloud service account keys — never commit
runnin-*-*.json
*service-account*.json
*-firebase-adminsdk-*.json
