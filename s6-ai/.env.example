# s6-ai — microsserviço de IA. Copie pra .env (dev), .env.staging, .env.production.
NODE_ENV=development
PORT=8080

# Firebase (verificação de ID tokens + Firestore do serviço:
# app_config/prompts, llm_usage, llm_pricing, rag_chunks, live_sessions).
# Em Cloud Run, omita CLIENT_EMAIL/PRIVATE_KEY e use a service account da
# instância (ADC) — mesmo padrão do runnin-api.
FIREBASE_PROJECT_ID=runnin-494520
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=

# LLM providers
GEMINI_API_KEY=
LLM_REALTIME_PROVIDER=gemini
LLM_ASYNC_PROVIDER=gemini
GEMINI_MODEL=
GEMINI_PLAN_MODEL=
GEMINI_LIVE_MODEL=models/gemini-2.5-flash-native-audio-latest
GEMINI_EMBEDDING_MODEL=
GROQ_API_KEY=
TOGETHER_API_KEY=

# Auth service-to-service (runnin-api -> s6-ai, rotas internas/admin).
# Em Cloud Run vem do Secret Manager via --set-secrets.
S6_INTERNAL_TOKEN=

LOG_LEVEL=info
