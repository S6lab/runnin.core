rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.admin == true ||
        request.auth.token.role == 'admin'
      );
    }

    function canAccessRun(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // App configuration - authenticated users can read, admins/editors can write
    match /app_config/{document=**} {
      allow read: if request.auth != null;
      allow write: if isAdmin() || request.auth.token.role == 'editor';
    }

    // User data
    match /users/{userId} {
      allow read, write: if canAccessRun(userId) || isAdmin();

      // User runs and nested collections
      match /runs/{runId} {
        allow read, write: if canAccessRun(userId) || isAdmin();
        match /reports/{reportId} {
          allow read, write: if canAccessRun(userId) || isAdmin();
        }
      }

      // User profile and settings
      match /{document=**} {
        allow read, write: if canAccessRun(userId) || isAdmin();
      }
    }

    // Public data
    match /public/{document=**} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
