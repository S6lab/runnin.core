                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  if (json.idToken) {",
                  "    pm.collectionVariables.set('idToken', json.idToken);",
                  "    console.log('idToken setado (uid=' + json.uid + ', expira em ' + json.expiresIn + 's)');",
